{
  "name": "Swipess",
  "short_name": "Swipess",
  "description": "Swipe to find properties, motorcycles, bicycles, and workers. Swipess is the elite multi-vertical marketplace.",
  "start_url": "/",
  "scope": "/",
  "display": "fullscreen",
  "display_override": ["fullscreen", "standalone", "minimal-ui", "window-controls-overlay"],
  "background_color": "#000000",
  "theme_color": "#000000",
  "orientation": "portrait-primary",
  "lang": "en",
  "dir": "ltr",
  "id": "com.swipes.app",
  "prefer_related_applications": false,
  "icons": [
    { "src": "/icons/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "maskable" }
  ],
  "categories": ["lifestyle", "business", "social"],
  "shortcuts": [
    { "name": "Browse Properties", "short_name": "Browse", "description": "Browse available rental properties", "url": "/client/dashboard", "icons": [{ "src": "/icons/icon-512.png", "sizes": "192x192" }] },
    { "name": "My Properties", "short_name": "Properties", "description": "Manage your rental properties", "url": "/owner/properties", "icons": [{ "src": "/icons/icon-512.png", "sizes": "192x192" }] },
    { "name": "Messages", "short_name": "Chat", "description": "View your conversations", "url": "/messages", "icons": [{ "src": "/icons/icon-512.png", "sizes": "192x192" }] }
  ],
  "related_applications": [{ "platform": "itunes", "url": "https://apps.apple.com/app/swipes/id1234567890" }],
  "launch_handler": { "client_mode": "navigate-existing" },
  "handle_links": "preferred",
  "edge_side_panel": { "preferred_width": 400 },
  "share_target": { "action": "/share", "method": "POST", "enctype": "multipart/form-data", "params": { "title": "title", "text": "text", "url": "url" } }
}
