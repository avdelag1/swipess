{
  "name": "Swipess",
  "short_name": "Swipess",
  "description": "Elite Multi-Vertical Marketplace: Discovery & Connection.",
  "start_url": "/?pwa=true",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "orientation": "portrait-primary",
  "lang": "en",
  "dir": "ltr",
  "id": "com.swipes.app.v1",
  "prefer_related_applications": false,
  "icons": [
    { "src": "/icons/icon-16.png",   "sizes": "16x16",     "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-32.png",   "sizes": "32x32",     "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-48.png",   "sizes": "48x48",     "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-96.png",   "sizes": "96x96",     "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "any" },
    { "src": "/icons/icon-1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any" },
    { "src": "/icons/fire-s-logo.webp", "sizes": "any",    "type": "image/webp", "purpose": "any" },
    { "src": "/icons/fire-s-logo.avif", "sizes": "any",    "type": "image/avif", "purpose": "any" },
    { "src": "/icons/maskable-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "maskable" },
    { "src": "/icons/maskable-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "maskable" }
  ],
  "categories": ["lifestyle", "business", "social"],
  "shortcuts": [
    { "name": "Discover", "short_name": "Discover", "description": "Explore the elite feed", "url": "/client/dashboard", "icons": [{ "src": "/icons/fire-s-logo-960.webp", "sizes": "192x192", "type": "image/webp" }] },
    { "name": "Radio", "short_name": "Radio", "description": "Listen to the vibe", "url": "/radio", "icons": [{ "src": "/icons/fire-s-logo-960.webp", "sizes": "192x192", "type": "image/webp" }] },
    { "name": "Messages", "short_name": "Chat", "description": "Global Concierge", "url": "/messages", "icons": [{ "src": "/icons/fire-s-logo-960.webp", "sizes": "192x192", "type": "image/webp" }] }
  ],
  "launch_handler": { "client_mode": "navigate-existing" },
  "handle_links": "preferred",
  "edge_side_panel": { "preferred_width": 400 }
}
