# Swipess Environment Variables
# ─────────────────────────────────────────────────────────────────────
# For LOCAL development: copy this file to .env and fill in your values.
# For LOVABLE deployment: set these in Lovable → Project Settings → Environment Variables.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────

# Supabase Configuration
# The anon/publishable key is safe to expose in client-side code.
# These values are also hardcoded as fallbacks in src/integrations/supabase/client.ts
# so the app works in Lovable preview even without env vars set.
VITE_SUPABASE_PROJECT_ID="vplgtcguxujxwrgguxqq"
VITE_SUPABASE_URL="https://vplgtcguxujxwrgguxqq.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZwbGd0Y2d1eHVqeHdyZ2d1eHFxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDgwMDI5MDIsImV4cCI6MjA2MzU3ODkwMn0.-TzSQ-nDho4J6TftVF4RNjbhr5cKbknQxxUT-AaSIJU"

# Web Push (VAPID) Public Key
# Optional — only needed for push notification subscriptions.
# If not set, push notification opt-in is silently disabled (app still works).
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
