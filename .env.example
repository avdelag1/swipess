# Swipess Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to source control

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Deployment Scripts
# Used by execution/deploy_edge_function.py
SUPABASE_PROJECT_REF="your-supabase-project-ref-id"
# SUPABASE_FUNCTION_SLUG="ai-orchestrator"  # optional, defaults to ai-orchestrator
# SUPABASE_FUNCTION_PATH="supabase/functions/ai-orchestrator/index.ts"  # optional

# Web Push (VAPID) Keys
# Generate with: node -e "const c=require('crypto');const {privateKey:pr,publicKey:pu}=c.generateKeyPairSync('ec',{namedCurve:'P-256',publicKeyEncoding:{type:'spki',format:'der'},privateKeyEncoding:{type:'sec1',format:'der'}});console.log('pub='+pu.subarray(27).toString('base64url'));console.log('priv='+pr.subarray(7,39).toString('base64url'));"
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# ─── AI Provider Keys (server-side only — set in Supabase Dashboard → Edge Functions → Secrets) ───
# These are NEVER exposed to the client. The ai-concierge function smart-routes
# between them based on task shape (structured/long → Kimi, casual → Gemini, fallback → MiniMax).

# Gemini (via Lovable AI Gateway) — primary for casual chat
LOVABLE_API_KEY="your-lovable-api-key"

# Kimi / Moonshot — preferred for structured JSON, long context, strict instruction-following
MOONSHOT_API_KEY="your-moonshot-api-key"

# MiniMax — legacy fallback
MINIMAX_API_KEY="your-minimax-api-key"

# Tavily — optional web search inside concierge
TAVILY_API_KEY="your-tavily-api-key"
