{
  "expo": {
    "name": "Swipess Mobile",
    "slug": "swipess-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swipess.mobile",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.swipess.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsDownloadToken": "sk.dummy_token_for_build"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Swipess to use your location for the Radar Nexus map discovery."
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "swipess-native-001"
      }
    }
  }
}
